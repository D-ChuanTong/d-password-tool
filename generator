<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>强密码生成器 - 免费在线密码生成工具</title>
    <meta name="description" content="免费在线强密码生成器，支持自定义长度、字符类型，一键生成安全密码并复制。">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        .toast { animation: fadeInOut 1.5s ease-in-out; }
        @keyframes fadeInOut {
            0% { opacity: 0; transform: translateY(10px); }
            20% { opacity: 1; transform: translateY(0); }
            80% { opacity: 1; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-10px); }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-900 to-slate-800 min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">
        <!-- 标题 -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-white mb-2">🔐 强密码生成器</h1>
            <p class="text-slate-400 text-sm">生成安全、随机的强密码</p>
        </div>

        <!-- 主卡片 -->
        <div class="bg-white rounded-2xl shadow-2xl p-6 space-y-6">

            <!-- 密码显示区域 -->
            <div class="relative">
                <div id="password-display" class="bg-slate-50 border-2 border-slate-200 rounded-xl p-4 pr-12 text-lg font-mono text-slate-800 break-all min-h-[60px] flex items-center select-all">
                    点击下方按钮生成密码
                </div>
                <button onclick="copyPassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-indigo-600 transition-colors" title="复制密码">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                </button>
            </div>

            <!-- 密码强度指示条 -->
            <div id="strength-bar-container" class="hidden">
                <div class="flex justify-between text-xs text-slate-500 mb-1">
                    <span>密码强度</span>
                    <span id="strength-text">强</span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-2">
                    <div id="strength-bar" class="h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>

            <!-- 密码长度 -->
            <div>
                <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-medium text-slate-700">密码长度</label>
                    <span id="length-value" class="text-sm font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded">16</span>
                </div>
                <input type="range" id="length-slider" min="4" max="64" value="16" class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600">
            </div>

            <!-- 字符类型选项 -->
            <div class="space-y-3">
                <p class="text-sm font-medium text-slate-700">包含字符</p>

                <label class="flex items-center justify-between cursor-pointer group">
                    <span class="text-sm text-slate-600 group-hover:text-slate-800">大写字母（A-Z）</span>
                    <input type="checkbox" id="include-uppercase" checked class="w-4 h-4 accent-indigo-600 rounded">
                </label>

                <label class="flex items-center justify-between cursor-pointer group">
                    <span class="text-sm text-slate-600 group-hover:text-slate-800">小写字母（a-z）</span>
                    <input type="checkbox" id="include-lowercase" checked class="w-4 h-4 accent-indigo-600 rounded">
                </label>

                <label class="flex items-center justify-between cursor-pointer group">
                    <span class="text-sm text-slate-600 group-hover:text-slate-800">数字（0-9）</span>
                    <input type="checkbox" id="include-numbers" checked class="w-4 h-4 accent-indigo-600 rounded">
                </label>

                <label class="flex items-center justify-between cursor-pointer group">
                    <span class="text-sm text-slate-600 group-hover:text-slate-800">特殊符号（!@#$%）</span>
                    <input type="checkbox" id="include-symbols" checked class="w-4 h-4 accent-indigo-600 rounded">
                </label>
            </div>

            <!-- 生成按钮 -->
            <button onclick="generatePassword()" class="w-full bg-indigo-600 hover:bg-indigo-700 active:scale-[0.98] text-white font-semibold py-3 px-4 rounded-xl transition-all duration-150 shadow-lg shadow-indigo-200">
                生成密码
            </button>
        </div>

        <!-- 底部提示 -->
        <p class="text-center text-slate-500 text-xs mt-4">密码在本地生成，不会上传到任何服务器</p>
        <!-- 导航：前往密码强度检测器
        <div class="text-center mt-4">
            <a href="strength.html" class="inline-flex items-center text-indigo-400 hover:text-white text-sm transition-colors">
                前往密码强度检测器
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
            </a>
        </div> -->
        <!-- 导航区域 -->
<div class="text-center mt-4 flex justify-center gap-4 text-sm">
    <a href="strength.html" class="text-indigo-400 hover:text-white transition-colors">检测强度</a>
    <span class="text-slate-600">|</span>
    <a href="passphrase.html" class="text-indigo-400 hover:text-white transition-colors">生成短语</a>
</div>
    </div>

    <!-- 复制成功提示 -->
    <div id="toast" class="hidden fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-sm px-4 py-2 rounded-lg shadow-lg">
        ✅ 已复制到剪贴板
    </div>

    <script>
        // 字符集
        const CHARSETS = {
            uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
            lowercase: 'abcdefghijklmnopqrstuvwxyz',
            numbers: '0123456789',
            symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'
        };

        // 获取 DOM 元素
        const lengthSlider = document.getElementById('length-slider');
        const lengthValue = document.getElementById('length-value');
        const passwordDisplay = document.getElementById('password-display');
        const strengthBarContainer = document.getElementById('strength-bar-container');
        const strengthBar = document.getElementById('strength-bar');
        const strengthText = document.getElementById('strength-text');

        // 滑块实时更新长度数字
        lengthSlider.addEventListener('input', () => {
            lengthValue.textContent = lengthSlider.value;
        });

        // 生成密码
        function generatePassword() {
            const length = parseInt(lengthSlider.value);
            const includeUpper = document.getElementById('include-uppercase').checked;
            const includeLower = document.getElementById('include-lowercase').checked;
            const includeNumbers = document.getElementById('include-numbers').checked;
            const includeSymbols = document.getElementById('include-symbols').checked;

            // 至少勾选一项
            if (!includeUpper && !includeLower && !includeNumbers && !includeSymbols) {
                passwordDisplay.textContent = '请至少选择一种字符类型';
                passwordDisplay.classList.add('text-red-500');
                strengthBarContainer.classList.add('hidden');
                return;
            }

            passwordDisplay.classList.remove('text-red-500');

            // 拼接选中的字符集
            let charset = '';
            let guaranteedChars = [];

            if (includeUpper) { charset += CHARSETS.uppercase; guaranteedChars.push(randomChar(CHARSETS.uppercase)); }
            if (includeLower) { charset += CHARSETS.lowercase; guaranteedChars.push(randomChar(CHARSETS.lowercase)); }
            if (includeNumbers) { charset += CHARSETS.numbers; guaranteedChars.push(randomChar(CHARSETS.numbers)); }
            if (includeSymbols) { charset += CHARSETS.symbols; guaranteedChars.push(randomChar(CHARSETS.symbols)); }

            // 生成随机密码
            let password = '';
            for (let i = 0; i < length; i++) {
                password += charset[Math.floor(Math.random() * charset.length)];
            }

            // 确保每种选中的字符类型至少出现一次
            guaranteedChars.forEach((char, index) => {
                if (index < length) {
                    const randomPos = Math.floor(Math.random() * length);
                    password = password.substring(0, randomPos) + char + password.substring(randomPos + 1);
                }
            });

            passwordDisplay.textContent = password;

            // 显示强度
            showStrength(password);
        }

        // 获取随机字符
        function randomChar(str) {
            return str[Math.floor(Math.random() * str.length)];
        }

        // 密码强度检测
        function showStrength(password) {
            strengthBarContainer.classList.remove('hidden');
            let score = 0;

            if (password.length >= 8) score++;
            if (password.length >= 12) score++;
            if (password.length >= 16) score++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
            if (/\d/.test(password)) score++;
            if (/[^a-zA-Z0-9]/.test(password)) score++;

            const levels = [
                { width: '15%', color: 'bg-red-500', text: '非常弱' },
                { width: '30%', color: 'bg-orange-500', text: '弱' },
                { width: '50%', color: 'bg-yellow-500', text: '一般' },
                { width: '70%', color: 'bg-lime-500', text: '较强' },
                { width: '85%', color: 'bg-green-500', text: '强' },
                { width: '100%', color: 'bg-emerald-600', text: '非常强' }
            ];

            const level = levels[Math.min(score, levels.length - 1)];
            strengthBar.style.width = level.width;
            strengthBar.className = `h-2 rounded-full transition-all duration-300 ${level.color}`;
            strengthText.textContent = level.text;
        }

        // 复制密码
        function copyPassword() {
            const password = passwordDisplay.textContent;
            if (!password || password === '点击下方按钮生成密码' || password === '请至少选择一种字符类型') return;

            navigator.clipboard.writeText(password).then(() => {
                showToast();
            });
        }

        // 提示弹窗
        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.remove('hidden');
            toast.classList.add('toast');
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('toast');
            }, 1500);
        }

        // 页面加载时自动生成一个密码
        generatePassword();
    </script>
</body>
</html>
